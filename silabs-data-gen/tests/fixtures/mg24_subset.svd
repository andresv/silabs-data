    </peripheral>
    <peripheral>
      <name>LDMA_NS</name>
      <version>2</version>
      <baseAddress>0x40010000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CHEN</name>
          <addressOffset>0x040</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>LETIMER0_NS</name>
      <version>2</version>
      <baseAddress>0x40020000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CNT</name>
          <addressOffset>0x010</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>RTCC_NS</name>
      <version>1</version>
      <baseAddress>0x40021000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CNT</name>
          <addressOffset>0x020</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>WDOG0_NS</name>
      <version>1</version>
      <baseAddress>0x40022000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CTRL</name>
          <addressOffset>0x008</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <!-- ===== Split kinds (3) — MG24 has older versions and different registers ===== -->
    <peripheral>
      <name>GPIO_NS</name>
      <version>3</version>
      <baseAddress>0x40011000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>PORTA_MODEL_V3</name>
          <addressOffset>0x100</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>CMU_NS</name>
