    </peripheral>
    <peripheral>
      <name>MSC_NS</name>
      <version>3</version>
      <baseAddress>0x40013000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
