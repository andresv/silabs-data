        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>MSC_NS</name>
      <version>9</version>
      <baseAddress>0x49013000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>WRITECTRL_V9</name>
          <addressOffset>0x00C</addressOffset>
