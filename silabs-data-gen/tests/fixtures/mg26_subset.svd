<?xml version="1.0" encoding="UTF-8"?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Silicon Labs</vendor>
  <vendorID>SLAB</vendorID>
  <name>FAKE_MG26_SUBSET</name>
  <series>EFR32</series>
  <version>B</version>
  <description>Hand-built MG26 subset mirroring the real-pack ground truth: 7 shared kinds (matching version + registers vs MG24) and 3 split kinds (GPIO v7, CMU v7, MSC v9 — different registers from MG24).</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <access>read-write</access>
  <resetValue>0</resetValue>
  <resetMask>4294967295</resetMask>
  <peripherals>
    <!-- ===== Shared kinds (7) — same version + same registers as MG24 ===== -->
    <peripheral>
      <name>ACMP0_NS</name>
      <version>2</version>
      <baseAddress>0x4900A000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CTRL</name>
          <addressOffset>0x008</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>BURTC_NS</name>
      <version>1</version>
      <baseAddress>0x4900B000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CNT</name>
          <addressOffset>0x010</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>EUSART0_NS</name>
      <version>2</version>
      <baseAddress>0x4900C000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CFG0</name>
          <addressOffset>0x008</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>TIMER0_NS</name>
      <version>3</version>
      <baseAddress>0x4900D000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>TOP</name>
          <addressOffset>0x020</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>USART0_NS</name>
      <version>4</version>
      <baseAddress>0x4900E000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>FRAME</name>
          <addressOffset>0x010</addressOffset>
          <size>32</size>
          <resetValue>0x00001005</resetValue>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>IADC0_NS</name>
      <version>1</version>
      <baseAddress>0x4900F000</baseAddress>
      <registers>
        <register>
          <name>EN</name>
          <addressOffset>0x004</addressOffset>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
        </register>
        <register>
          <name>CTRL</name>
          <addressOffset>0x008</addressOffset>
